<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cancel"
        android:src="@drawable/ic_arrow_back"
        app:tint="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/textSelectorTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:fontFamily="@font/ndot_57"
        android:textColor="?attr/colorOnSurface"
        android:textSize="40sp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/textStyleName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="?attr/colorOnSurface"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/textStyleCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/ndot_57"
        android:gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textVibrationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/vibration_intensity"
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp" />

    <org.duhen.dglyphs.BrightnessSliderView
        android:id="@+id/seekVibration"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/slider_bg" />

</LinearLayout>