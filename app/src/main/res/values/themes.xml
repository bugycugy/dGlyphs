<resources>

    <style name="Base.Theme.DGlyphs" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#F2F2F2</item>
        <item name="colorOnSurface">#000000</item>
        <item name="colorOutline">#99000000</item>
        <item name="colorSurfaceVariant">#FFFFFF</item>
        <item name="colorPrimary">#000000</item>
    </style>

    <style name="Theme.DGlyphs" parent="Base.Theme.DGlyphs" />

    <style name="DayButtonStyle" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="shapeAppearanceOverlay">@style/CircleShape</item>
        <item name="android:fontFamily">@font/ndot_57</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">#E0E0E0</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="CircleShape">
        <item name="cornerSize">50%</item>
    </style>
</resources>